APP_NAME="WhatsApp Insurance Chatbot"
APP_ENV=local
# --- Local ---
DATABASE_URL=sqlite:///./data/chatbot.db

# --- Producción (Render + Supabase) ---
# Usar la URL directa de Supabase (puerto 5432, NO el pooler PgBouncer).
# Las tablas se crean automáticamente en el schema "chatbot" al iniciar.
# DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-1-us-east-1.pooler.supabase.com:5432/postgres

WHATSAPP_VERIFY_TOKEN=change-me
WHATSAPP_ACCESS_TOKEN=change-me
WHATSAPP_PHONE_NUMBER_ID=change-me
WHATSAPP_API_VERSION=v21.0

# --- Local: apunta al mock interno ---
MAIN_SYSTEM_BASE_URL=mock
MAIN_SYSTEM_API_KEY=change-me

# --- Producción: apunta a my-app en Vercel ---
# MAIN_SYSTEM_BASE_URL=https://<tu-app>.vercel.app/api/chatbot
# MAIN_SYSTEM_API_KEY=<mismo valor que CHATBOT_API_KEY en Vercel>

OUTBOUND_API_KEY=change-me

ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
SESSION_SECRET_KEY=change-me-session-secret


