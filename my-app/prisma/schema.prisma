generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// =============================================================================
// ENUMS
// =============================================================================

enum ClienteTipo {
  corporativo
  persona
}

enum ClienteEstado {
  activo
  baja
}

enum PolizaEstado {
  vigente
  proxima
  vencida
  anulada
  renovada
}

enum CoberturaTipo {
  responsabilidad_civil
  terceros_completo
  todo_riesgo
  basica
  integral
}

enum SiniestroEstado {
  nuevo
  tramite
  cerrado
}

enum DocumentoTipo {
  img
  pdf
}

enum PagoEstado {
  pendiente
  validado
  rechazado
}

enum Rol {
  productor
  administrativo
}

// =============================================================================
// CLIENTES
// =============================================================================

model clientes {
  id                Int           @id @default(autoincrement())
  tipo              ClienteTipo
  email             String?
  telefono          String?
  direccion         String?
  estado            ClienteEstado @default(activo)
  fecha_alta        DateTime      @default(now()) @db.Timestamptz(6)
  created_at        DateTime      @default(now()) @db.Timestamptz(6)
  updated_at        DateTime      @updatedAt @db.Timestamptz(6)
  modificado_por_id Int?
  modificado_en     DateTime?     @db.Timestamptz(6)

  clientes_corporativos    clientes_corporativos?
  clientes_no_corporativos clientes_no_corporativos?
  polizas                  polizas[]
  pagos                    pagos[]
  modificado_por           usuarios?                 @relation("ClienteModificadoPor", fields: [modificado_por_id], references: [id], onDelete: SetNull)

  @@index([tipo])
  @@index([estado])
}

model clientes_corporativos {
  cliente_id      Int      @id
  cuit            String   @unique
  razon_social    String
  contacto_nombre String?
  clientes        clientes @relation(fields: [cliente_id], references: [id], onDelete: Cascade)
}

model clientes_no_corporativos {
  cliente_id Int      @id
  dni        String   @unique
  nombre     String
  apellido   String
  clientes   clientes @relation(fields: [cliente_id], references: [id], onDelete: Cascade)
}

// =============================================================================
// ASEGURADORAS
// =============================================================================

model empresas_aseguradoras {
  id                Int       @id @default(autoincrement())
  razon_social      String
  cuit              String    @unique
  telefono          String?
  email             String?
  contacto_nombre   String?
  direccion         String?
  created_at        DateTime  @default(now()) @db.Timestamptz(6)
  updated_at        DateTime  @updatedAt @db.Timestamptz(6)
  modificado_por_id Int?
  modificado_en     DateTime? @db.Timestamptz(6)

  polizas        polizas[]
  modificado_por usuarios? @relation("AseguradoraModificadaPor", fields: [modificado_por_id], references: [id], onDelete: SetNull)
}

// =============================================================================
// TIPOS DE SEGURO
// =============================================================================

model tipos_seguro {
  id          Int     @id @default(autoincrement())
  nombre      String  @unique
  descripcion String?

  polizas polizas[]
}

// =============================================================================
// PÓLIZAS
// =============================================================================

model polizas {
  id                         Int           @id @default(autoincrement())
  numero_poliza              String        @unique
  cliente_id                 Int
  aseguradora_id             Int
  tipo_seguro_id             Int
  cobertura                  CoberturaTipo
  estado                     PolizaEstado
  fecha_emision              DateTime      @db.Timestamptz(6)
  fecha_inicio_vigencia      DateTime      @db.Timestamptz(6)
  fecha_fin_vigencia         DateTime      @db.Timestamptz(6)
  suma_asegurada             Decimal       @db.Decimal(15, 2)
  prima_mensual              Decimal       @db.Decimal(15, 2)
  moneda                     String        @default("ARS") @db.Char(3)
  tarjeta_circulacion_poliza String?
  numero_cuota               Int?
  pago_id                    Int?
  created_at                 DateTime      @default(now()) @db.Timestamptz(6)
  updated_at                 DateTime      @updatedAt @db.Timestamptz(6)
  modificado_por_id          Int?
  modificado_en              DateTime?     @db.Timestamptz(6)

  cliente        clientes              @relation(fields: [cliente_id], references: [id])
  aseguradora    empresas_aseguradoras @relation(fields: [aseguradora_id], references: [id])
  tipo_seguro    tipos_seguro          @relation(fields: [tipo_seguro_id], references: [id])
  pago           pagos?                @relation(fields: [pago_id], references: [id], onDelete: SetNull)
  siniestros     siniestros[]
  modificado_por usuarios?             @relation("PolizaModificadaPor", fields: [modificado_por_id], references: [id], onDelete: SetNull)

  @@index([cliente_id])
  @@index([aseguradora_id])
  @@index([tipo_seguro_id])
  @@index([estado])
  @@index([fecha_fin_vigencia])
  @@index([pago_id])
  @@index([estado, fecha_fin_vigencia])
}

// =============================================================================
// SINIESTROS
// =============================================================================

model siniestros {
  id                 Int             @id @default(autoincrement())
  poliza_id          Int
  numero             String          @unique
  titulo             String
  fecha_ocurrencia   DateTime        @db.Timestamptz(6)
  fecha_reporte      DateTime        @db.Timestamptz(6)
  descripcion_hechos String?
  estado             SiniestroEstado @default(nuevo)
  leido              Boolean         @default(false)
  ai_summary         String?
  created_at         DateTime        @default(now()) @db.Timestamptz(6)
  updated_at         DateTime        @updatedAt @db.Timestamptz(6)
  modificado_por_id  Int?
  modificado_en      DateTime?       @db.Timestamptz(6)

  poliza         polizas                @relation(fields: [poliza_id], references: [id], onDelete: Cascade)
  documentos     siniestro_documentos[]
  modificado_por usuarios?              @relation("SiniestroModificadoPor", fields: [modificado_por_id], references: [id], onDelete: SetNull)

  @@index([poliza_id])
  @@index([estado])
  @@index([leido])
  @@index([fecha_reporte(sort: Desc)])
  @@index([estado, leido])
}

model siniestro_documentos {
  id           Int           @id @default(autoincrement())
  siniestro_id Int
  tipo         DocumentoTipo
  nombre       String
  url          String
  mime_type    String
  hash         String?
  tamano_bytes Int?
  created_at   DateTime      @default(now()) @db.Timestamptz(6)

  siniestro siniestros @relation(fields: [siniestro_id], references: [id], onDelete: Cascade)

  @@index([siniestro_id])
}

// =============================================================================
// PAGOS (un pago agrupa N pólizas)
// =============================================================================

model pagos {
  id                Int        @id @default(autoincrement())
  cliente_id        Int
  monto             Decimal    @db.Decimal(15, 2)
  fecha_pago        DateTime?  @db.Timestamptz(6)
  estado            PagoEstado @default(pendiente)
  metodo_pago       String?
  comprobante       String?
  cbu               String?
  moneda            String     @default("ARS") @db.Char(3)
  created_at        DateTime   @default(now()) @db.Timestamptz(6)
  updated_at        DateTime   @updatedAt @db.Timestamptz(6)
  modificado_por_id Int?
  modificado_en     DateTime?  @db.Timestamptz(6)

  cliente        clientes  @relation(fields: [cliente_id], references: [id])
  polizas        polizas[]
  modificado_por usuarios? @relation("PagoModificadoPor", fields: [modificado_por_id], references: [id], onDelete: SetNull)

  @@index([cliente_id])
  @@index([estado])
  @@index([fecha_pago(sort: Desc)])
  @@index([cliente_id, estado])
}

// =============================================================================
// USUARIOS
// =============================================================================

model usuarios {
  id              Int      @id @default(autoincrement())
  dni             String   @unique
  email           String   @unique
  password_hash   String
  nombre_completo String
  rol             Rol
  created_at      DateTime @default(now()) @db.Timestamptz(6)

  clientes_modificados     clientes[]              @relation("ClienteModificadoPor")
  polizas_modificadas      polizas[]               @relation("PolizaModificadaPor")
  siniestros_modificados   siniestros[]            @relation("SiniestroModificadoPor")
  pagos_modificados        pagos[]                 @relation("PagoModificadoPor")
  aseguradoras_modificadas empresas_aseguradoras[] @relation("AseguradoraModificadaPor")
}
