generator client {
  provider        = "prisma-client"
  output          = "../app/generated/prisma"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "postgresql"
}

model clientes {
  id                       Int                       @id @default(autoincrement())
  tipo                     ClienteTipo
  email                    String?
  telefono                 String?                   @unique(map: "clientes_telefono_activo_uniq", where: raw("((estado = 'activo'::\"ClienteEstado\") AND (telefono IS NOT NULL))"))
  direccion                String?
  estado                   ClienteEstado             @default(activo)
  fecha_alta               DateTime                  @default(now()) @db.Timestamptz(6)
  created_at               DateTime                  @default(now()) @db.Timestamptz(6)
  updated_at               DateTime                  @updatedAt @db.Timestamptz(6)
  modificado_por_id        Int?
  modificado_en            DateTime?                 @db.Timestamptz(6)
  /// Código de asegurado en la cartera de Berkley (sync diario). Null = cliente
  /// que no proviene de Berkley. Unique para poder upsert por este código.
  codigo_asegurado_berkley String?                   @unique
  /// Fila cruda original del archivo `asegur` de Berkley (respaldo del sync).
  raw_berkley              Json?
  modificado_por           usuarios?                 @relation("ClienteModificadoPor", fields: [modificado_por_id], references: [id])
  clientes_corporativos    clientes_corporativos?
  clientes_no_corporativos clientes_no_corporativos?
  pagos                    pagos[]
  poliza_clientes          poliza_clientes[]
  polizas                  polizas[]
  solicitudes_polizas      solicitudes_polizas[]

  @@index([tipo])
  @@index([estado])
  @@index([telefono])
}

model clientes_corporativos {
  cliente_id      Int      @id
  cuit            String   @unique
  razon_social    String
  contacto_nombre String?
  clientes        clientes @relation(fields: [cliente_id], references: [id], onDelete: Cascade)
}

model clientes_no_corporativos {
  cliente_id Int      @id
  dni        String   @unique
  nombre     String
  apellido   String
  clientes   clientes @relation(fields: [cliente_id], references: [id], onDelete: Cascade)
}

model empresas_aseguradoras {
  id                 Int       @id @default(autoincrement())
  razon_social       String
  cuit               String    @unique
  telefono           String?
  email              String?
  created_at         DateTime  @default(now()) @db.Timestamptz(6)
  updated_at         DateTime  @updatedAt @db.Timestamptz(6)
  modificado_por_id  Int?
  modificado_en      DateTime? @db.Timestamptz(6)
  /// Slug del adapter de integración (ej. "berkley", "federacion_patronal").
  /// Null = aseguradora sin integración API. Las credenciales viven en env vars.
  codigo_integracion String?
  modificado_por     usuarios? @relation("AseguradoraModificadaPor", fields: [modificado_por_id], references: [id])
  polizas            polizas[]
}

model tipos_seguro {
  id          Int              @id @default(autoincrement())
  nombre      String           @unique
  categoria   CategoriaSeguro
  /// FK a la rama genérica (provider-agnostic). Es la clave canónica con la que
  /// cada aseguradora mapea su código de rama interno a un tipo de seguro común.
  /// Unique: una sola fila de tipos_seguro por rama genérica.
  rama_id     Int?             @unique
  rama        ramas_genericas? @relation(fields: [rama_id], references: [id])
  descripcion String?
  coberturas  coberturas[]
  polizas     polizas[]

  @@index([categoria])
}

/// Catálogo de ramas de seguro genéricas (provider-agnostic). Cada aseguradora
/// mapea su código de rama interno a una fila de esta tabla. Reemplaza al enum
/// fijo para poder agregar ramas nuevas como dato (INSERT) sin migración: si
/// Berkley (u otra) manda una rama desconocida, el sync la crea acá al vuelo.
model ramas_genericas {
  id           Int           @id @default(autoincrement())
  /// Slug estable y único (ej. "automotor", "flota_automotor"). Clave canónica
  /// con la que se conectan los tipos_seguro y los mapeos por aseguradora.
  codigo       String        @unique
  nombre       String
  descripcion  String?
  created_at   DateTime      @default(now()) @db.Timestamptz(6)
  tipos_seguro tipos_seguro?
}

model coberturas {
  id                    Int                   @id @default(autoincrement())
  tipo_seguro_id        Int
  nombre                String
  descripcion           String?
  /// FK a la cobertura genérica (provider-agnostic). Permite que coberturas de
  /// distintas aseguradoras/tipos mapeen a una misma cobertura canónica.
  cobertura_generica_id Int?
  cobertura_generica    coberturas_genericas? @relation(fields: [cobertura_generica_id], references: [id])
  tipo_seguro           tipos_seguro          @relation(fields: [tipo_seguro_id], references: [id], onDelete: Cascade)
  polizas               polizas[]

  @@unique([tipo_seguro_id, nombre])
  @@index([tipo_seguro_id])
  @@index([cobertura_generica_id])
}

/// Catálogo de coberturas genéricas (provider-agnostic). Cada aseguradora mapea
/// su cobertura interna a una fila de esta tabla. Igual que ramas_genericas: una
/// cobertura nueva entra como dato (INSERT) sin migración; el sync la crea al vuelo
/// a partir de la descripción de cobert.txt.
model coberturas_genericas {
  id          Int          @id @default(autoincrement())
  /// Slug estable y único (ej. "todo_riesgo", "responsabilidad_civil").
  codigo      String       @unique
  nombre      String
  descripcion String?
  created_at  DateTime     @default(now()) @db.Timestamptz(6)
  coberturas  coberturas[]
}

model polizas {
  id                       Int                   @id @default(autoincrement())
  numero_poliza            String                @unique
  cliente_id               Int
  aseguradora_id           Int
  /// Nullable: las pólizas importadas de la cartera Berkley entran como datos
  /// parciales (borrador) sin tipo/cobertura/suma/prima hasta completarse a mano.
  tipo_seguro_id           Int?
  cobertura_id             Int?
  pago_id                  Int?
  estado                   PolizaEstado
  fecha_inicio_vigencia    DateTime?             @db.Timestamptz(6)
  fecha_fin_vigencia       DateTime?             @db.Timestamptz(6)
  suma_asegurada           Decimal?              @db.Decimal(15, 2)
  /// Cuota mensual fija que el cliente abona para mantener la póliza vigente.
  /// Capturada al momento de la emisión.
  prima_mensual            Decimal?              @db.Decimal(15, 2)
  moneda                   String                @default("ARS") @db.Char(3)
  created_at               DateTime              @default(now()) @db.Timestamptz(6)
  updated_at               DateTime              @updatedAt @db.Timestamptz(6)
  modificado_por_id        Int?
  modificado_en            DateTime?             @db.Timestamptz(6)
  dominio                  String?
  tarjeta_circulacion_mime String?
  tarjeta_circulacion_pdf  String?
  /// Datos específicos de la cartera Berkley (sync diario). Null = póliza que no
  /// proviene de Berkley. La clave natural Berkley es rama + poliza + suplemento.
  rama                     String?
  raw_berkley              Json?
  suplemento               String?
  poliza_clientes          poliza_clientes[]
  aseguradora              empresas_aseguradoras @relation(fields: [aseguradora_id], references: [id])
  cliente                  clientes              @relation(fields: [cliente_id], references: [id])
  cobertura                coberturas?           @relation(fields: [cobertura_id], references: [id])
  modificado_por           usuarios?             @relation("PolizaModificadaPor", fields: [modificado_por_id], references: [id])
  pago                     pagos?                @relation(fields: [pago_id], references: [id])
  tipo_seguro              tipos_seguro?         @relation(fields: [tipo_seguro_id], references: [id])
  siniestros               siniestros[]

  @@index([cliente_id])
  @@index([aseguradora_id])
  @@index([tipo_seguro_id])
  @@index([cobertura_id])
  @@index([estado])
  @@index([fecha_fin_vigencia])
  @@index([pago_id])
  @@index([estado, fecha_fin_vigencia])
}

/// Clientes adicionales (co-asegurados) vinculados a una póliza, además del
/// titular principal en `polizas.cliente_id`. Permite asociar una póliza a más
/// de un cliente.
model poliza_clientes {
  poliza_id  Int
  cliente_id Int
  es_titular Boolean  @default(false)
  cliente    clientes @relation(fields: [cliente_id], references: [id], onDelete: Cascade)
  poliza     polizas  @relation(fields: [poliza_id], references: [id], onDelete: Cascade)

  @@id([poliza_id, cliente_id])
  @@index([cliente_id])
}

model siniestros {
  id                Int                    @id @default(autoincrement())
  poliza_id         Int
  /// Identificador visible al cliente (formato `SIN-NNNNN`), generado por la
  /// aplicación con prefijo + secuencia al crear el siniestro. Distinto del id interno.
  numero            String                 @unique
  titulo            String
  fecha_ocurrencia  DateTime               @db.Timestamptz(6)
  fecha_reporte     DateTime               @db.Timestamptz(6)
  estado            SiniestroEstado        @default(nuevo)
  created_at        DateTime               @default(now()) @db.Timestamptz(6)
  updated_at        DateTime               @updatedAt @db.Timestamptz(6)
  modificado_por_id Int?
  modificado_en     DateTime?              @db.Timestamptz(6)
  descripcion       String
  documentos        siniestro_documentos[]
  lecturas          siniestro_lecturas[]
  modificado_por    usuarios?              @relation("SiniestroModificadoPor", fields: [modificado_por_id], references: [id])
  poliza            polizas                @relation(fields: [poliza_id], references: [id], onDelete: Cascade)

  @@index([poliza_id])
  @@index([estado])
  @@index([fecha_reporte(sort: Desc)])
}

model siniestro_documentos {
  id           Int           @id @default(autoincrement())
  siniestro_id Int
  tipo         DocumentoTipo
  nombre       String
  url          String?
  mime_type    String
  tamano_bytes Int?
  created_at   DateTime      @default(now()) @db.Timestamptz(6)
  contenido    Bytes?
  siniestro    siniestros    @relation(fields: [siniestro_id], references: [id], onDelete: Cascade)

  @@index([siniestro_id])
}

/// Registra qué usuario leyó qué siniestro y cuándo.
/// Reemplaza al flag `siniestros.leido` (que mezclaba estado de UI con dominio).
model siniestro_lecturas {
  siniestro_id Int
  usuario_id   Int
  leido_en     DateTime   @default(now()) @db.Timestamptz(6)
  siniestro    siniestros @relation(fields: [siniestro_id], references: [id], onDelete: Cascade)
  usuario      usuarios   @relation(fields: [usuario_id], references: [id], onDelete: Cascade)

  @@id([siniestro_id, usuario_id])
  @@index([usuario_id])
}

model pagos {
  id                    Int         @id @default(autoincrement())
  cliente_id            Int
  monto                 Decimal     @db.Decimal(15, 2)
  fecha_pago            DateTime?   @db.Timestamptz(6)
  estado                PagoEstado  @default(pendiente)
  metodo_pago           MetodoPago?
  moneda                String      @default("ARS") @db.Char(3)
  created_at            DateTime    @default(now()) @db.Timestamptz(6)
  updated_at            DateTime    @updatedAt @db.Timestamptz(6)
  modificado_por_id     Int?
  modificado_en         DateTime?   @db.Timestamptz(6)
  comprobante_contenido Bytes?
  comprobante_mime      String?
  comprobante_nombre    String?
  cliente               clientes    @relation(fields: [cliente_id], references: [id])
  modificado_por        usuarios?   @relation("PagoModificadoPor", fields: [modificado_por_id], references: [id])
  polizas               polizas[]
  documentos            pago_documentos[]

  @@index([cliente_id])
  @@index([estado])
  @@index([fecha_pago(sort: Desc)])
  @@index([cliente_id, estado])
}

model pago_documentos {
  id           Int           @id @default(autoincrement())
  pago_id      Int
  tipo         DocumentoTipo
  nombre       String
  url          String?
  mime_type    String
  tamano_bytes Int?
  created_at   DateTime      @default(now()) @db.Timestamptz(6)
  pago         pagos         @relation(fields: [pago_id], references: [id], onDelete: Cascade)

  @@index([pago_id])
}

model usuarios {
  id                       Int                     @id @default(autoincrement())
  dni                      String?                 @unique
  email                    String                  @unique
  password_hash            String
  nombre_completo          String
  rol                      Rol
  created_at               DateTime                @default(now()) @db.Timestamptz(6)
  clientes_modificados     clientes[]              @relation("ClienteModificadoPor")
  aseguradoras_modificadas empresas_aseguradoras[] @relation("AseguradoraModificadaPor")
  pagos_modificados        pagos[]                 @relation("PagoModificadoPor")
  polizas_modificadas      polizas[]               @relation("PolizaModificadaPor")
  siniestros_leidos        siniestro_lecturas[]
  siniestros_modificados   siniestros[]            @relation("SiniestroModificadoPor")
}

model noticias_scrapeadas {
  id           Int       @id @default(autoincrement())
  url_origen   String    @unique
  titulo       String
  resumen      String?
  imagen_url   String?
  publicada_en DateTime? @db.Timestamptz(6)
  categoria    String?
  fuente       String    @default("Asegurando Digital")
  scrapeada_en DateTime  @default(now()) @db.Timestamptz(6)

  @@index([publicada_en(sort: Desc)])
  @@index([scrapeada_en(sort: Desc)])
}

model solicitudes_polizas {
  id             Int                   @id @default(autoincrement())
  numero         String                @unique
  cliente_id     Int?
  telefono       String
  insurance_type TipoSeguroSolicitud
  dominio        String
  marca          String
  modelo         String
  anio           String
  uso            UsoVehiculo
  notas          String?
  estado         SolicitudPolizaEstado @default(nueva)
  created_at     DateTime              @default(now()) @db.Timestamptz(6)
  updated_at     DateTime              @updatedAt @db.Timestamptz(6)
  cliente        clientes?             @relation(fields: [cliente_id], references: [id])

  @@index([cliente_id])
  @@index([telefono])
  @@index([estado])
  @@index([created_at(sort: Desc)])
}

/// Estado del sync diario de Berkley (singleton: una sola fila).
/// `ultima_corrida` es el FechaDesde de la próxima llamada a apwsnovedades.
model berkley_sync_state {
  id             Int       @id @default(1)
  ultima_corrida DateTime? @db.Timestamptz(6)
  updated_at     DateTime  @updatedAt @db.Timestamptz(6)
}

/// Log de cada archivo GD descargado en una corrida del sync.
model berkley_sync_archivos {
  id                 Int       @id @default(autoincrement())
  nombre             String
  link               String
  fecha_modificacion DateTime? @db.Timestamptz(6)
  hash               String?
  tamano_bytes       Int?
  descargado_en      DateTime  @default(now()) @db.Timestamptz(6)

  @@index([nombre])
  @@index([descargado_en(sort: Desc)])
}

/// Cambios detectados al parsear los archivos GD (altas y modificaciones).
/// Iteración 1: se registran para revisión, sin upsert a las tablas de dominio.
model berkley_novedades {
  id           Int                @id @default(autoincrement())
  tipo         BerkleyNovedadTipo
  archivo      String
  rama         String?
  poliza       String?
  suplemento   String?
  payload      Json
  detectada_en DateTime           @default(now()) @db.Timestamptz(6)
  procesada    Boolean            @default(false)

  @@index([tipo])
  @@index([procesada])
  @@index([detectada_en(sort: Desc)])
}

enum BerkleyNovedadTipo {
  alta
  cambio
}

enum ClienteTipo {
  corporativo
  persona
}

enum ClienteEstado {
  activo
  baja
}

enum PolizaEstado {
  vigente
  vencida
}

enum SiniestroEstado {
  nuevo
  pendiente_documentacion
  en_tramite
  cerrado
  rechazado
}

enum CategoriaSeguro {
  auto
  vida
  hogar
  salud
  comercio
  art
  agricola
  otros
}

enum MetodoPago {
  transferencia
  debito_automatico
  tarjeta_credito
  tarjeta_debito
  efectivo
  mercadopago
  cheque
  otro
}

enum DocumentoTipo {
  img
  pdf
}

enum PagoEstado {
  pendiente
  validado
  rechazado
}

enum Rol {
  productor
  administrativo
  sin_acceso
}

enum TipoSeguroSolicitud {
  auto
  moto
}

enum UsoVehiculo {
  particular
  comercial
}

enum SolicitudPolizaEstado {
  nueva
  aceptada
  rechazada
}
